"""
name: diamond-number-star-sandwich
Purpose: This code generates a diamond number star sandwich pattern based on the input number `n`.

"""
n = int(input("Enter the number: "))
for i in range(1, n + 1):
    for j in range(i):
        print(i, end="")
        if j != i - 1:
            print("*", end="")
    print()
for i in range(n, 0, -1):
    for j in range(i):
        print(i, end="")
        if j != i - 1:
            print("*", end="")
    print()