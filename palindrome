"""
name: palindrome.py
Purpose: This program checks if a given string is a palindrome or not.

"""
def pali(n):
    n = n.lower()
    left, right = 0, len(n) - 1
    while left < right:
        if n[left] != n[right]:
            return False
        left += 1
        right -= 1
    return True
a=input("Enter a string to check if it's a palindrome: ")
if pali(a):
    print(a," is a palindrome")
else:
    print(a," is not a palindrome")   