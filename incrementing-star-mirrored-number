"""
name: incrementing-star-mirrored-number
Purpose: This code generates an incrementing star mirrored number pattern based on the input number `a`.

"""
a=int(input("Enter the number of rows: "))
n = 1
for i in range(n , a+1):
    start = n + i - 1
    for j in range(i):
            print(start, end=" ")
            start -= 1
            n+=1
            if j != i - 1:
                print("*", end=" ")
    print()