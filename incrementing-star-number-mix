a = int(input("Enter the number of rows: "))
starts = [1]
for i in range(1, a):
    starts.append(starts[-1] + i)
order = list(range(1, a + 1))
for i in range(1, len(order) - 1, 2):
    order[i], order[i + 1] = order[i + 1], order[i]
for i in order:
    n = starts[i - 1]
    for j in range(i):
        print(n, end="")
        n += 1
        if j != i - 1:
            print("*", end="")
    print()