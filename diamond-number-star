"""
name: diamond-number-star
Purpose: This code generates a diamond number star pattern based on the input number `n`.

"""
n = int(input("Enter the number: "))
for i in range(1, 2 * n):
    if i <= n:
        value = i
    else:
        value = 2 * n - i
    for j in range(value):
        print(value, end="")
        if j != value - 1:
            print("*", end="")
    print()