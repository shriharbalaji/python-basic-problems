a = int(input("Enter the number of rows: "))
rows = []
n = 1
for i in range(1, a + 1):
    start = n + i - 1
    row = ""
    for j in range(i):
        row += str(start)
        start -= 1
        if j != i - 1:
            row += "*"
    rows.append(row)
    n += i
for row in reversed(rows):
    print(row)