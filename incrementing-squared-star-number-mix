"""
name: incrementing-squared-star-number-mix
Purpose: This code generates an incrementing squared star number pattern with a mix of rows based on the input number `a`.

"""
a = int(input("Enter the number of rows: "))
rows = []
n = 1
for i in range(a):
    row = ""
    for j in range(a):
        row += str(n)
        n += 1
        if j != a - 1:
            row += "*"
    rows.append(row)
for i in range(1, len(rows) - 1, 2):
    rows[i], rows[i + 1] = rows[i + 1], rows[i]
for row in rows:
    print(row)